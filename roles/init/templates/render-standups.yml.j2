resources:
  - name: inventory-trigger
    type: git
    webhook_token: ((github/webhook.key))
    check_every: 30s
    source:
      uri: "{{ inventory_repo }}"
      branch: "{{ inventory_version }}"
      private_key: ((github_ssh_private_key.key))

jobs:
  - name: render-standups
    plan:
      - get: inventory-trigger
        trigger: true
      - task: render-standups
        privileged: true
        config:
          platform: linux
          image_resource:
            type: registry-image
            source:
              repository: "{{ registry_fqdn }}/prov"
              tag: latest
          inputs:
            - name: inventory-trigger
          params:
            PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
            CONCOURSE_URL: "{{ concourse_url }}"
            CONCOURSE_TEAM: "{{ concourse_team }}"
            CONCOURSE_USER: "{{ concourse_user }}"
            CONCOURSE_PASSWORD: "{{ lookup('env', 'CONCOURSE_PASSWORD') }}"
            IS_BOOTSTRAP_ENV: "false"
            VAULT_ADDR: "{{ vault_bootstrap_url }}"
            VAULT_TOKEN: ((root_token.key))
          run:
            path: /bin/bash
            user: keiichi
            dir: /homelab
            args:
              - -lc
              - |
                  set -euo pipefail

                  fly -t bootstrap login \
                    -c "${CONCOURSE_URL}" \
                    -u "${CONCOURSE_USER}" \
                    -p "${CONCOURSE_PASSWORD}" \
                    -n "${CONCOURSE_TEAM}"

                  placeholder_open='(('
                  placeholder_close='))'
                  capture_group_var="${placeholder_open}inventory_capture_group_name${placeholder_close}"
                  github_key_var="${placeholder_open}github_ssh_private_key.key${placeholder_close}"
                  github_webhook_key_var="${placeholder_open}github_webhook_token.key${placeholder_close}"

                  cat > /tmp/server-standup.yml <<EOF
                  resources:
                    - name: inventory-trigger
                      type: git
                      check_every: 30s
                      webhook_token: ${github_webhook_key_var}
                      source:
                        uri: "{{ inventory_repo }}"
                        branch: "${capture_group_var}"
                        private_key: ${github_key_var}

                  jobs:
                    - name: standup
                      plan:
                        - get: inventory-trigger
                          trigger: true
                        - task: show-inventory-capture-group
                          privileged: true
                          config:
                            platform: linux
                            image_resource:
                              type: registry-image
                              source:
                                repository: "{{ registry_fqdn }}/prov"
                                tag: latest
                            inputs:
                              - name: inventory-trigger
                            params:
                              PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
                              INVENTORY_CAPTURE_GROUP_NAME: "${capture_group_var}"
                              IS_BOOTSTRAP_ENV: "false"
                              VAULT_ADDR: "{{ vault_bootstrap_url }}"
                              VAULT_TOKEN: ((root_token.key))
                            run:
                              path: /bin/bash
                              user: keiichi
                              dir: /homelab
                              args:
                                - -lc
                                - |
                                    set -euo pipefail
                                    echo "Standup pipeline for \${INVENTORY_CAPTURE_GROUP_NAME}"
                                    curl -fsS "\${PROV_CONTROLLER_API_URL%/}/inventorycapturegroups/\${INVENTORY_CAPTURE_GROUP_NAME}" | jq .
                  EOF

                  mapfile -t inventory_capture_group_names < <(
                    curl -fsS "${PROV_CONTROLLER_API_URL%/}/inventorycapturegroups/" \
                    | jq -r '.[].metadata.name'
                  )

                  if [ -z "${inventory_capture_group_names[*]:-}" ]; then
                    echo "No inventory capture groups found"
                    exit 0
                  fi

                  mapfile -t existing_pipelines < <(
                    fly -t bootstrap pipelines --json | jq -r '.[].name'
                  )

                  for group_name in "${inventory_capture_group_names[@]}"; do
                    pipeline_name="standup-${group_name}"

                    if printf '%s\n' "${existing_pipelines[@]}" | grep -qx "${pipeline_name}"; then
                      echo "Pipeline ${pipeline_name} already exists"
                      continue
                    fi

                    fly -t bootstrap set-pipeline \
                      -p "${pipeline_name}" \
                      --non-interactive \
                      -c /tmp/server-standup.yml \
                      -v inventory_capture_group_name="${group_name}"

                    fly -t bootstrap unpause-pipeline -p "${pipeline_name}"
                  done
