resources:
  - name: inventory
    type: git
    check_every: 30s
    source:
      uri: "{{ inventory_repo }}"
      branch: "((inventory_capture_group_name))"

jobs:
  - name: standup
    plan:
      - get: inventory
        trigger: true
      - task: show-inventory-capture-group
        privileged: true
        config:
          platform: linux
          image_resource:
            type: registry-image
            source:
              repository: "{{ registry_ipv4 }}:5000/prov"
              tag: latest
              insecure_registries:
                - "{{ registry_ipv4 }}:5000"
          inputs:
            - name: inventory
          params:
            PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
            INVENTORY_CAPTURE_GROUP_NAME: "((inventory_capture_group_name))"
          run:
            path: /bin/bash
            user: keiichi
            args:
              - -lc
              - |
                  set -euo pipefail
                  echo "Standup pipeline for ${INVENTORY_CAPTURE_GROUP_NAME}"
                  curl -fsS "${PROV_CONTROLLER_API_URL%/}/inventorycapturegroups/${INVENTORY_CAPTURE_GROUP_NAME}" | jq .
