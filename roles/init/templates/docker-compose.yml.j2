volumes:
  ssl_certs:
    driver: local
  vault_shared:
    driver: local
  concourse_keys:
    driver: local
  prov_controller_inventory_repo:
    driver: local
  prov_controller_hostvars_repo:
    driver: local

services:
  webhook:
    build: ./webhook
    ports:
      - "3001:3001"
    secrets:
      - droplet_ssh_key
    restart: always
    networks:
      clusternet:
        ipv4_address: "{{ webhook_ipv4 }}"
    environment:
        WEBHOOK_TOKEN: "{{ lookup('env', 'GITHUB_WEBHOOK_SECRET') }}"
        CI_URL: "{{ concourse_fqdn }}"
  registry:
    image: registry
    container_name: registry
    restart: always
    ports:
      - 5000:5000
    volumes:
      - "{{ host_data_path }}/registry/data:/var/lib/registry:rw"
    networks:
      clusternet:
        ipv4_address: "{{ registry_ipv4 }}"

  concourse-keys:
    image: alpine
    container_name: concourse-keys
    command: |
      sh -c "
        apk add --no-cache openssh-client
        if [ ! -f /concourse-keys/session_signing_key ]; then
          ssh-keygen -t rsa -m PEM -f /concourse-keys/session_signing_key -N ''
          ssh-keygen -t rsa -m PEM -f /concourse-keys/tsa_host_key -N ''
          cp /concourse-keys/session_signing_key.pub /concourse-keys/authorized_worker_keys
        fi
        exit 0
      "
    volumes:
      - concourse_keys:/concourse-keys
    restart: on-failure

  concourse-db:
    container_name: concourse-db
    image: postgres
    environment:
      POSTGRES_DB: concourse
      POSTGRES_PASSWORD: concourse_pass
      POSTGRES_USER: concourse_user
      PGDATA: /database
      POSTGRES_HOST_AUTH_METHOD: trust
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U concourse_user -d concourse"]
      interval: 3s
      timeout: 3s
      retries: 5
    networks:
      clusternet:
        ipv4_address: "{{ concourse_db_ipv4 }}"

  concourse-web:
    container_name: concourse-web
    build:
      context: ./concourse
      args:
        CONCOURSE_VERSION: "{{ concourse_version }}"
    command: web
    privileged: true
    depends_on:
      concourse-db:
        condition: service_healthy
      concourse-keys:
        condition: service_completed_successfully
      vault:
        condition: service_healthy
    ports:
      - "8080:8080"
      - "2222:2222"
    volumes:
      - concourse_keys:/concourse-keys
      - vault_shared:/shared
    environment:
      CONCOURSE_SESSION_SIGNING_KEY: /concourse-keys/session_signing_key
      CONCOURSE_TSA_HOST_KEY: /concourse-keys/tsa_host_key
      CONCOURSE_TSA_AUTHORIZED_KEYS: /concourse-keys/authorized_worker_keys
      CONCOURSE_POSTGRES_HOST: "{{ concourse_db_ipv4 }}"
      CONCOURSE_POSTGRES_USER: concourse_user
      CONCOURSE_POSTGRES_PASSWORD: concourse_pass
      CONCOURSE_POSTGRES_DATABASE: concourse
      CONCOURSE_EXTERNAL_URL: "{{ concourse_url }}"
      CONCOURSE_ADD_LOCAL_USER: "{{ concourse_user }}:{{ lookup('env', 'CONCOURSE_PASSWORD') }}"
      CONCOURSE_MAIN_TEAM_LOCAL_USER: "{{ concourse_user }}"
      CONCOURSE_CLUSTER_NAME: homelab
      CONCOURSE_VAULT_URL: "{{ vault_bootstrap_url }}"
      CONCOURSE_VAULT_SHARED_PATH: shared
    restart: always
    networks:
      clusternet:
        ipv4_address: "{{ concourse_ipv4 }}"

  concourse-worker:
    container_name: concourse-worker
    build:
      context: ./concourse
      args:
        CONCOURSE_VERSION: "{{ concourse_version }}"
    command: worker
    privileged: true
    cgroup: host
    depends_on:
      - concourse-web
    volumes:
      - concourse_keys:/concourse-keys
      - "{{ host_data_path }}/vault/vault_stuff/stuff:/stuff"
      - vault_shared:/shared
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      CONCOURSE_TSA_HOST: concourse-web:2222
      CONCOURSE_TSA_PUBLIC_KEY: /concourse-keys/tsa_host_key.pub
      CONCOURSE_TSA_WORKER_PRIVATE_KEY: /concourse-keys/session_signing_key
      CONCOURSE_RUNTIME: containerd
      CONCOURSE_CONTAINERD_ALLOW_HOST_ACCESS: "true"
      CONCOURSE_VAULT_URL: "{{ vault_bootstrap_url }}"
      CONCOURSE_VAULT_SHARED_PATH: shared
      CONCOURSE_CONTAINERD_DNS_PROXY_ENABLE: "true"
    restart: always
    networks:
      - clusternet

  http:
    build: ./provisioning-api
    ports:
      - "3000:3000"
      - "8000:8000"
    secrets:
      - git_provisioning_key
    restart: always
    networks:
      clusternet:
        ipv4_address: "{{ server_api_ipv4 }}"
    environment:
      CONCOURSE_URL: "{{ concourse_url }}"
      CONCOURSE_USER: "{{ concourse_user }}"
      CONCOURSE_PASSWORD: "{{ lookup('env', 'CONCOURSE_PASSWORD') }}"
      CONCOURSE_TEAM: "{{ concourse_team }}"
      CONCOURSE_COMMANDS_PIPELINE: "{{ concourse_commands_pipeline }}"
      CONCOURSE_COMMANDS_RESOURCE: "{{ concourse_commands_resource }}"
      CONCOURSE_OAUTH_CLIENT_ID: "{{ concourse_oauth_client_id }}"
      CONCOURSE_OAUTH_CLIENT_SECRET: "{{ lookup('env', 'CONCOURSE_OAUTH_CLIENT_SECRET') }}"

  prov-controller-redis:
    image: redis:7-alpine
    container_name: prov-controller-redis
    command:
      - redis-server
      - --appendonly
      - "yes"
      - --appendfsync
      - everysec
      - --save
      - "60 1000"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: always
    networks:
      - clusternet

  prov-controller:
    build: ./prov-controller
    container_name: prov-controller
    depends_on:
      prov-controller-redis:
        condition: service_healthy
    secrets:
      - git_provisioning_key
    restart: always
    environment:
      REDIS_URL: redis://prov-controller-redis:6379
      CONCOURSE_URL: "{{ concourse_url }}"
      CONCOURSE_USER: "{{ concourse_user }}"
      CONCOURSE_PASSWORD: "{{ lookup('env', 'CONCOURSE_PASSWORD') }}"
      CONCOURSE_TEAM: "{{ concourse_team }}"
      CONCOURSE_ISO_PIPELINE: build-isos
      CONCOURSE_ISO_JOB: build-isos
      NGINX_FILES_BASE_URL: "https://{{ nginx_acme_label }}"
      NGINX_FILES_DIR: /srv/nginx-files
      REDIS_ENFORCE_PERSISTENCE: "true"
      INVENTORY_REPO_DIR: /repos/homelab-inventory
      HOSTVARS_REPO_DIR: /repos/homelab-hostvars
      INVENTORY_REPO_URL: "{{ inventory_repo }}"
      HOSTVARS_REPO_URL: "{{ hostvars_repo }}"
      INVENTORY_REPO_BRANCH: "{{ inventory_version }}"
      HOSTVARS_REPO_BRANCH: "{{ hostvars_version }}"
      GIT_AUTO_CLONE: "true"
      GIT_PULL_ENABLED: "true"
      GIT_PUSH_ENABLED: "true"
      GIT_AUTHOR_NAME: "{{ groupvars_git_user_name }}"
      GIT_AUTHOR_EMAIL: "{{ groupvars_git_user_email }}"
      GIT_SSH_COMMAND: "ssh -i /run/secrets/git_provisioning_key -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"
    volumes:
      - prov_controller_inventory_repo:/repos/homelab-inventory
      - prov_controller_hostvars_repo:/repos/homelab-hostvars
      - "{{ host_data_path }}/nginx/files:/srv/nginx-files"
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8001/api/v1/routers/ >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 10s
    networks:
      clusternet:
        ipv4_address: "{{ prov_controller_ipv4 }}"

  vault:
    build: ./vault
    container_name: vault
    ports:
      - 8200:8200
    cap_add:
      - IPC_LOCK
    restart: always
    volumes:
      - "{{ host_data_path }}/vault/vault_stuff/internal:/vault/data"
      - "{{ host_data_path }}/vault/vault_stuff/config:/vault/config"
      - "{{ host_data_path }}/vault/vault_stuff/logs:/vault/logs"
      - "{{ host_data_path }}/vault/vault_stuff/secrets:/vault/secrets"
      - "{{ host_data_path }}/vault/vault_stuff/stuff:/stuff"
      - vault_shared:/shared
      - ssl_certs:/vault/ssl:ro
    environment:
      VAULT_ADDR: "http://127.0.0.1:8200"
      VAULT_API_ADDR: "http://vault:8200"
    networks:
      clusternet:
        ipv4_address: "{{ vault_ipv4 }}"
    healthcheck:
      test: ["CMD", "vault", "status"]
      interval: 5s
      retries: 5
      start_period: 5s

  nginx:
    build: ./nginx
    container_name: nginx
    networks:
      clusternet:
        ipv4_address: "{{ nginx_ipv4 }}"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - "{{ host_data_path }}/nginx/files:/www/data"
      - ssl_certs:/etc/nginx/ssl:rw
    restart: always
    labels:
      - sh.acme.autoload.domain={{ nginx_acme_label }}

  dnsmasq:
    build: ./dnsmasq
    network_mode: host
    depends_on:
      - nginx
    restart: always
    cap_add:
      - NET_ADMIN

  acme:
    build: ./acme
    container_name: acme
    network_mode: host
    environment:
      - CF_Token="{{ lookup('env', 'CLOUDFLARE_API_KEY') }}"
      - CF_Email="{{ cloudflare_email }}"
      - ACME_DOMAIN={{ cloudflare_domain }}
      - ACME_SERVER={{ cert_authority }}
      - ZEROSSL_EAB_KID={{ lookup('env', 'ZEROSSL_EAB_KID') }}
      - ZEROSSL_EAB_HMAC_KEY={{ lookup('env', 'ZEROSSL_EAB_HMAC_KEY') }}
      - ZEROSSL_EMAIL={{ zerossl_email }}
      - DNS_API=dns_cf
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - "{{ host_data_path }}/acme/acme.sh:/acme.sh"
      - ssl_certs:/certs:rw
    restart: always
    depends_on:
      - nginx
    healthcheck:
      test: ["CMD", "test", "-f", "/done"]
      interval: 10s
      retries: 5000
      start_period: 10s

  postgres:
    image: postgres:15
    container_name: osdb
    restart: always
    environment:
      POSTGRES_USER: "{{ postgres_user }}"
      POSTGRES_PASSWORD: "{{ lookup('env', 'POSTGRES_PASSWORD') }}"
      POSTGRES_DB: "{{ postgres_db }}"
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - "{{ host_data_path }}/postgres/data:/var/lib/postgresql/data:rw"
    networks:
      clusternet:
        ipv4_address: "{{ postgres_ipv4 }}"

secrets:
  git_provisioning_key:
    file: "{{ host_git_ssh_key_path }}"
  droplet_ssh_key:
    file: "{{ droplet_ssh_key_path }}"

networks:
  clusternet:
    driver: "{{ network_driver }}"
    driver_opts:
      mode: "{{ ipvlan_mode if network_driver == 'ipvlan' else macvlan_mode }}"
      parent: "{{ interface }}"
    ipam:
      config:
        - subnet: "{{ ipvlan_subnet if network_driver == 'ipvlan' else macvlan_subnet }}"
          gateway: "{{ ipvlan_gateway if network_driver == 'ipvlan' else macvlan_gateway }}"
