resources:
  - name: ansible-roles
    type: git
    check_every: 720h
    source:
      uri: "{{ lookup('env', 'GIT_ANSIBLE_ROLES_REPO') | default('git@github.com:asdf57/ansible-roles.git', true) }}"
      branch: "{{ lookup('env', 'GIT_ANSIBLE_ROLES_BRANCH') | default('main', true) }}"
      private_key: ((github_ssh_private_key.key))

{% set iso_build_task_combos = [
  {"task_name": "build-arch-iso", "distro": "arch", "artifact_type": "iso", "image": "prov-iso-task-arch"},
  {"task_name": "build-arch-netboot", "distro": "arch", "artifact_type": "netboot", "image": "prov-iso-task-arch"},
  {"task_name": "build-debian-trixie-iso", "distro": "debian_trixie", "artifact_type": "iso", "image": "prov-iso-task-debian-trixie"},
  {"task_name": "build-debian-trixie-netboot", "distro": "debian_trixie", "artifact_type": "netboot", "image": "prov-iso-task-debian-trixie"},
] %}

jobs:
  - name: build-isos
    plan:
      - get: ansible-roles
      - task: prepare-request
        config:
          platform: linux
          image_resource:
            type: registry-image
            source:
              repository: "{{ registry_fqdn }}/prov-iso-task-arch"
              tag: latest
          outputs:
            - name: request
          params:
            PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
          run:
            path: /bin/bash
            args:
              - -lc
              - |
                  set -euo pipefail

                  output_dir="$PWD/request"
                  mkdir -p "${output_dir}"
                  status_code="$(
                    curl -sS \
                      -o "${output_dir}/current-response.json" \
                      -w '%{http_code}' \
                      "${PROV_CONTROLLER_API_URL%/}/isobuilds/current"
                  )"

                  if [[ "${status_code}" != "200" ]]; then
                    echo "Failed to fetch active ISO build request (HTTP ${status_code})" >&2

                    if [[ -s "${output_dir}/current-response.json" ]]; then
                      echo "Controller response:" >&2
                      cat "${output_dir}/current-response.json" >&2
                    fi

                    if [[ "${status_code}" == "404" ]]; then
                      overview_status="$(
                        curl -sS \
                          -o "${output_dir}/overview-response.json" \
                          -w '%{http_code}' \
                          "${PROV_CONTROLLER_API_URL%/}/isobuilds/"
                      )"

                      if [[ "${overview_status}" == "200" ]] && [[ -s "${output_dir}/overview-response.json" ]]; then
                        current_status="$(jq -r '.currentRequest.status // empty' "${output_dir}/overview-response.json" 2>/dev/null || true)"
                        current_id="$(jq -r '.currentRequest.id // empty' "${output_dir}/overview-response.json" 2>/dev/null || true)"

                        if [[ -n "${current_status}" ]]; then
                          echo "Current ISO request ${current_id:-<unknown>} exists but is not active (status=${current_status})." >&2
                        else
                          echo "No active ISO build request exists. This usually means the job was run manually or the request already finished." >&2
                        fi
                      fi
                    fi

                    exit 1
                  fi

                  request_json="$(cat "${output_dir}/current-response.json")"
                  printf '%s' "${request_json}" > "${output_dir}/request.json"

                  request_id="$(printf '%s' "${request_json}" | jq -r '.id')"
                  requested_distros_label="$(printf '%s' "${request_json}" | jq -r '.distros | join(", ")')"
                  requested_build_types_label="$(printf '%s' "${request_json}" | jq -r '.artifactTypes | join(", ")')"

                  curl -fsS \
                    -X POST \
                    -H 'Content-Type: application/json' \
                    -d "$(jq -nc --arg status 'Running' --arg message "Building ${requested_build_types_label} artifacts for ${requested_distros_label}." '{status: $status, message: $message}')" \
                    "${PROV_CONTROLLER_API_URL%/}/isobuilds/${request_id}/status" >/dev/null

      - in_parallel:
          fail_fast: true
          steps:
{% for combo in iso_build_task_combos %}
            - task: {{ combo.task_name }}
              privileged: true
              config:
                platform: linux
                image_resource:
                  type: registry-image
                  source:
                    repository: "{{ registry_fqdn }}/{{ combo.image }}"
                    tag: latest
                inputs:
                  - name: ansible-roles
                  - name: request
                params:
                  PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
                  VAULT_ADDR: "{{ vault_bootstrap_url }}"
                  VAULT_TOKEN: ((root_token.key))
                run:
                  path: /bin/bash
                  args:
                    - -lc
                    - |
                        set -euo pipefail

                        request_file="$PWD/request/request.json"
                        if [[ ! -f "${request_file}" ]]; then
                          echo "Missing request artifact"
                          exit 1
                        fi

                        request_json="$(cat "${request_file}")"

                        if ! printf '%s' "${request_json}" | jq -e '.distros | index("{{ combo.distro }}")' >/dev/null; then
                          echo "{{ combo.distro }} {{ combo.artifact_type }} not requested: distro missing"
                          exit 0
                        fi

                        if ! printf '%s' "${request_json}" | jq -e '.artifactTypes | index("{{ combo.artifact_type }}")' >/dev/null; then
                          echo "{{ combo.distro }} {{ combo.artifact_type }} not requested: artifact type missing"
                          exit 0
                        fi

                        provisioning_key="$(
                          curl -fsS \
                            -H "X-Vault-Token: ${VAULT_TOKEN}" \
                            "${VAULT_ADDR%/}/v1/kv2/data/provisioning/ssh/public" \
                          | jq -er '.data.data.key'
                        )"

                        printf '%s\n' "${provisioning_key}" > /tmp/provisioning_key.pub
                        chmod 0644 /tmp/provisioning_key.pub

                        export ANSIBLE_HOST_KEY_CHECKING=False
                        export ANSIBLE_ROLES_PATH="$PWD/ansible-roles/roles"
                        export ANSIBLE_FILTER_PLUGINS="$PWD/ansible-roles/ansible/filter_plugins"
                        export ISO_BUILD_EXECUTION_MODE=direct
                        export ISO_PROVISIONING_PUBLIC_KEY_PATH=/tmp/provisioning_key.pub

                        output_root="/tmp/iso-build-output"
                        rm -rf "${output_root}"
                        mkdir -p "${output_root}/nginx/files"

                        ansible-playbook \
                          -i localhost, \
                          -c local \
                          ansible-roles/plays/build_isos.yml \
                          -e "mounted_data_path=${output_root}" \
                          -e "host_data_path=${output_root}" \
                          -e 'requested_build_distros_json=["{{ combo.distro }}"]' \
                          -e 'requested_build_types_json=["{{ combo.artifact_type }}"]' \
                          -e '{"force_build":true}'

                        artifact_dir="${output_root}/nginx/files/{{ combo.distro }}_{{ combo.artifact_type }}"
                        if [[ ! -d "${artifact_dir}" ]]; then
                          echo "Expected artifact directory ${artifact_dir} was not created"
                          exit 1
                        fi

                        archive_path="$(mktemp /tmp/{{ combo.distro }}_{{ combo.artifact_type }}.XXXXXX.tar.gz)"
                        tar -czf "${archive_path}" -C "${artifact_dir}" .
                        request_id="$(printf '%s' "${request_json}" | jq -r '.id')"
                        curl -fsS \
                          -X POST \
                          -F "archive=@${archive_path};filename={{ combo.distro }}_{{ combo.artifact_type }}.tar.gz" \
                          "${PROV_CONTROLLER_API_URL%/}/isobuilds/${request_id}/artifacts/{{ combo.distro }}/{{ combo.artifact_type }}" >/dev/null
                        rm -f "${archive_path}"
{% endfor %}
        on_success:
          task: mark-succeeded
          config:
            platform: linux
            image_resource:
              type: registry-image
              source:
                repository: "{{ registry_fqdn }}/prov-iso-task-arch"
                tag: latest
            inputs:
              - name: request
            params:
              PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
            run:
              path: /bin/bash
              args:
                - -lc
                - |
                    set -euo pipefail

                    request_file="$PWD/request/request.json"
                    if [[ ! -f "${request_file}" ]]; then
                      echo "Missing request artifact; skipping success status update"
                      exit 0
                    fi

                    request_json="$(cat "${request_file}")"
                    request_id="$(printf '%s' "${request_json}" | jq -r '.id')"
                    requested_distros_label="$(printf '%s' "${request_json}" | jq -r '.distros | join(", ")')"
                    requested_build_types_label="$(printf '%s' "${request_json}" | jq -r '.artifactTypes | join(", ")')"

                    curl -fsS \
                      -X POST \
                      -H 'Content-Type: application/json' \
                      -d "$(jq -nc --arg status 'Succeeded' --arg message "Built ${requested_build_types_label} artifacts for ${requested_distros_label}." '{status: $status, message: $message}')" \
                      "${PROV_CONTROLLER_API_URL%/}/isobuilds/${request_id}/status" >/dev/null
        on_failure:
          task: mark-failed
          config:
            platform: linux
            image_resource:
              type: registry-image
              source:
                repository: "{{ registry_fqdn }}/prov-iso-task-arch"
                tag: latest
            inputs:
              - name: request
            params:
              PROV_CONTROLLER_API_URL: "{{ prov_controller_api_url }}"
            run:
              path: /bin/bash
              args:
                - -lc
                - |
                    set -euo pipefail

                    request_file="$PWD/request/request.json"
                    if [[ ! -f "${request_file}" ]]; then
                      echo "Missing request artifact; skipping failure status update"
                      exit 0
                    fi

                    request_json="$(cat "${request_file}")"
                    request_id="$(printf '%s' "${request_json}" | jq -r '.id')"
                    requested_distros_label="$(printf '%s' "${request_json}" | jq -r '.distros | join(", ")')"
                    requested_build_types_label="$(printf '%s' "${request_json}" | jq -r '.artifactTypes | join(", ")')"

                    curl -fsS \
                      -X POST \
                      -H 'Content-Type: application/json' \
                      -d "$(jq -nc --arg status 'Failed' --arg message "Build failed for ${requested_distros_label} (${requested_build_types_label})." '{status: $status, message: $message}')" \
                      "${PROV_CONTROLLER_API_URL%/}/isobuilds/${request_id}/status" >/dev/null
